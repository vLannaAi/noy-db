# Playground Nuxt .env.example — copy to .env (gitignored) and fill in
# the providers you want the /oidc page to offer. Any provider whose
# client ID is left blank simply doesn't render a button on the page.
#
# See docs/oidc-providers.md for provider-by-provider setup walkthroughs.
# Every redirect URI below expects the page at http://localhost:3000/oidc
# (the playground's default dev server). Change to your deployed URL
# when deploying.

# ─── Google ─────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
# Authorized redirect URI: http://localhost:3000/oidc
NUXT_PUBLIC_OIDC_GOOGLE_CLIENT_ID=

# ─── Apple (Sign in with Apple) ─────────────────────────────────────
# Apple Developer → Certificates, Identifiers & Profiles → Identifiers →
# + → Services IDs. Configure Sign in with Apple; add redirect URL.
# The client ID is the Services ID (reverse-DNS form, e.g. com.firm.app).
NUXT_PUBLIC_OIDC_APPLE_CLIENT_ID=

# ─── LINE (LINE Login) ──────────────────────────────────────────────
# LINE Developers Console → Providers → Create Channel → LINE Login.
# LINE uses "Channel ID" rather than "client ID" but it's the same thing.
NUXT_PUBLIC_OIDC_LINE_CHANNEL_ID=

# ─── Meta / Facebook Login ──────────────────────────────────────────
# developers.facebook.com → My Apps → Create App → Facebook Login.
# The "App ID" is the client ID. Note: Meta's web flow is OAuth2-first;
# standard OIDC id_token is emitted only in some flows. See
# docs/oidc-providers.md for caveats.
NUXT_PUBLIC_OIDC_META_CLIENT_ID=

# ─── Auth0 (universal bridge) ───────────────────────────────────────
# Auth0 Dashboard → Applications → Create Application → SPA.
# Domain looks like "dev-foo.us.auth0.com" (no https://).
NUXT_PUBLIC_OIDC_AUTH0_DOMAIN=
NUXT_PUBLIC_OIDC_AUTH0_CLIENT_ID=

# ─── Keycloak (self-hosted, great for CI / offline) ─────────────────
# Docker:
#   docker run -p 8080:8080 -e KEYCLOAK_ADMIN=admin \
#     -e KEYCLOAK_ADMIN_PASSWORD=admin \
#     quay.io/keycloak/keycloak:latest start-dev
# Issuer URL form: http://localhost:8080/realms/<realm-name>
NUXT_PUBLIC_OIDC_KEYCLOAK_ISSUER=
NUXT_PUBLIC_OIDC_KEYCLOAK_CLIENT_ID=
