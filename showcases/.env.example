# Showcase environment — copy to `.env` (gitignored) and fill in only the
# sections for services you want to run against. Every credential-gated
# showcase skips cleanly when its vars are unset, so an empty `.env` still
# produces a green test run for the local-only showcases.
#
# Conventions:
#   - Variable names are `NOYDB_SHOWCASE_<SERVICE>_<KEY>`.
#   - Empty values count as unset — the gate stays closed.
#   - Never commit a populated `.env`. Repo `.gitignore` already excludes it,
#     but treat that as a safety net, not the primary control.

# ─── AWS (DynamoDB single-table + S3 object store) ──────────────────────
# Showcases: 04 (mocked, always runs), 04b (real, gated), to-aws-s3.
#
# Credentials and region come from the AWS profile named below — the AWS
# SDK v3 default credential-provider chain reads ~/.aws/credentials and
# ~/.aws/config without us touching `fromIni` directly.
NOYDB_SHOWCASE_AWS_PROFILE=

# Cleanup mode (1 = delete records in afterAll, 0 = leave for inspection).
NOYDB_SHOWCASE_AWS_CLEANUP=1

# Resource name overrides (only needed if your CFN stack uses non-defaults).
# NOYDB_SHOWCASE_DYNAMO_TABLE=noydb-showcase
# NOYDB_SHOWCASE_S3_BUCKET=noydb-showcase-blobs

# ─── Cloudflare R2 (S3-compatible, zero egress) ─────────────────────────
# 1. Account ID: any page in dash.cloudflare.com → right sidebar.
# 2. Bucket: dash → R2 Object Storage → Create bucket (default name below
#    falls back to 'noydb-showcase-r2' if you leave _BUCKET blank).
# 3. Access keys: dash → R2 Object Storage → Account Details → Manage API
#    Tokens → Create API Token → Object Read & Write. Both keys display
#    ONCE — copy immediately.
#
# NOTE: "Secrets Store" in the Cloudflare dashboard is a different product
# (a runtime vault for Worker bindings + AI Gateway provider keys). External
# clients like this showcase still use the API-token credentials above.
NOYDB_SHOWCASE_R2_ACCOUNT_ID=
NOYDB_SHOWCASE_R2_ACCESS_KEY_ID=
NOYDB_SHOWCASE_R2_SECRET_ACCESS_KEY=
NOYDB_SHOWCASE_R2_BUCKET=

# ─── Cloudflare D1 (edge SQLite via REST) ───────────────────────────────
# 1. Account ID: any page in dash.cloudflare.com → right sidebar.
# 2. Database: dash → Workers & Pages → D1 → Create database. The DB ID
#    is shown on the database's overview page (also in URL).
# 3. API token: dash → top-right avatar → My Profile → API Tokens →
#    Create Token → Custom token → Account: D1: Edit permission, scoped
#    to your account. Copy the token (one-time view).
NOYDB_SHOWCASE_D1_ACCOUNT_ID=
NOYDB_SHOWCASE_D1_DATABASE_ID=
NOYDB_SHOWCASE_D1_API_TOKEN=

# ─── Postgres (node-postgres + jsonb column) ────────────────────────────
# Any standard postgres URL: postgres://user:pass@host:5432/database
# Local dev: `docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres:16`
NOYDB_SHOWCASE_POSTGRES_URL=

# ─── Supabase (hosted Postgres + Storage) ───────────────────────────────
# Three values needed because the showcase exercises BOTH the Postgres
# (records) and Storage (blobs) sides of Supabase. The variable names
# match the labels Supabase uses in its current dashboard UI.
#
# 1. SUPABASE_URL — project REST URL (https://<ref>.supabase.co), shown
#    on the project's home page (Settings → API → Project URL).
# 2. SUPABASE_SECRET_KEY — the privileged backend key. Settings → API →
#    "Secret Key" tab (or "service_role" in the legacy JWT format on older
#    dashboards). NOT the anon / publishable key — that's read-only on
#    Storage and would fail the showcase's writes.
# 3. SUPABASE_DB_URL — direct Postgres URL with password. Settings →
#    Database → Connection string → switch dropdown to "Session pooler"
#    if your network is IPv4-only (most home/office). Format:
#    postgresql://postgres.<ref>:<pwd>@<region>.pooler.supabase.com:5432/postgres
NOYDB_SHOWCASE_SUPABASE_URL=
NOYDB_SHOWCASE_SUPABASE_SECRET_KEY=
NOYDB_SHOWCASE_SUPABASE_DB_URL=

# ─── MySQL (mysql2 + JSON column) ───────────────────────────────────────
# mysql://user:pass@host:3306/database
NOYDB_SHOWCASE_MYSQL_URL=

# ─── Turso (hosted libSQL, replicated SQLite) ───────────────────────────
# libsql://<db-name>-<org>.turso.io  +  CLI-issued auth token.
NOYDB_SHOWCASE_TURSO_URL=
NOYDB_SHOWCASE_TURSO_AUTH_TOKEN=

# ─── WebDAV (Nextcloud / ownCloud / Apache mod_dav) ─────────────────────
# Base URL ends at the user's WebDAV root, e.g.
#   https://nc.example.com/remote.php/dav/files/alice/
NOYDB_SHOWCASE_WEBDAV_URL=
NOYDB_SHOWCASE_WEBDAV_USERNAME=
NOYDB_SHOWCASE_WEBDAV_PASSWORD=

# ─── SSH / SFTP (public-key auth only — no password fallback) ───────────
# The remote dir must already exist and be writable by the SSH user.
NOYDB_SHOWCASE_SSH_HOST=
NOYDB_SHOWCASE_SSH_USER=
NOYDB_SHOWCASE_SSH_KEY_PATH=
NOYDB_SHOWCASE_SSH_REMOTE_DIR=

# ─── SMB / CIFS (NTLM v2 or Kerberos) ───────────────────────────────────
# Server is the hostname or IP of the SMB server; share is the export name.
NOYDB_SHOWCASE_SMB_SERVER=
NOYDB_SHOWCASE_SMB_SHARE=
NOYDB_SHOWCASE_SMB_USERNAME=
NOYDB_SHOWCASE_SMB_PASSWORD=

# ─── NFS (host-level mount must exist before the test runs) ─────────────
# Path is the local mount point — the showcase doesn't mount; it just reads/writes.
NOYDB_SHOWCASE_NFS_MOUNT=

# ─── iCloud Drive (macOS-only path presence check) ──────────────────────
# Default: ~/Library/Mobile Documents/com~apple~CloudDocs/noydb-showcase
NOYDB_SHOWCASE_ICLOUD_PATH=

# ─── Google Drive (OAuth refresh token, not service account) ────────────
# Generate via the OAuth playground or your own consent flow; scope:
#   https://www.googleapis.com/auth/drive.appdata
NOYDB_SHOWCASE_DRIVE_CLIENT_ID=
NOYDB_SHOWCASE_DRIVE_CLIENT_SECRET=
NOYDB_SHOWCASE_DRIVE_REFRESH_TOKEN=
