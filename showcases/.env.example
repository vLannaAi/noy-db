# Showcase environment — copy to .env (gitignored) and fill in.
#
# All cloud showcases (#10 Cloud DynamoDB, #11 AWS Split Store) skip cleanly
# unless NOYDB_SHOWCASE_AWS_PROFILE is set. Everything else runs in pure
# memory and needs no configuration.

# Name of the AWS profile defined in ~/.aws/credentials or ~/.aws/config.
# The region assigned to that profile is used automatically — no override
# here. Leave unset to skip all AWS showcases.
NOYDB_SHOWCASE_AWS_PROFILE=

# Cleanup mode. Default behaviour is ON.
#   1 — (default) delete records written by each test in afterAll.
#   0 — leave records in place (useful for post-mortem inspection).
# Stack teardown (removing the DynamoDB table + S3 bucket) is always manual:
#   aws cloudformation delete-stack --stack-name noydb-showcase
NOYDB_SHOWCASE_AWS_CLEANUP=1

# Overrides — only needed if you deploy the CFN stack with custom names,
# or run parallel test environments on the same AWS account.
# NOYDB_SHOWCASE_DYNAMO_TABLE=noydb-showcase
# NOYDB_SHOWCASE_S3_BUCKET=noydb-showcase-blobs
