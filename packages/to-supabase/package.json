{
  "name": "@noy-db/to-supabase",
  "version": "0.1.0",
  "description": "Supabase adapter for noy-db — Postgres + Storage combo. Routes records to @noy-db/to-postgres via the Supabase Postgres pool and optional blob routing via Supabase Storage.",
  "license": "MIT",
  "author": "vLannaAi <vicio@lanna.ai>",
  "homepage": "https://github.com/vLannaAi/noy-db/tree/main/packages/to-supabase#readme",
  "repository": { "type": "git", "url": "https://github.com/vLannaAi/noy-db.git", "directory": "packages/to-supabase" },
  "bugs": { "url": "https://github.com/vLannaAi/noy-db/issues" },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=18.0.0" },
  "scripts": { "build": "tsup", "test": "vitest run", "lint": "eslint src/", "typecheck": "tsc --noEmit" },
  "peerDependencies": {
    "@noy-db/hub": "workspace:*",
    "@noy-db/to-postgres": "workspace:*"
  },
  "devDependencies": {
    "@noy-db/hub": "workspace:*",
    "@noy-db/to-postgres": "workspace:*",
    "@types/node": "^22.0.0"
  },
  "keywords": ["noy-db", "to-supabase", "supabase", "postgres", "storage"]
}
