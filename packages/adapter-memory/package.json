{
  "name": "@noydb/memory",
  "version": "0.0.1",
  "description": "In-memory adapter for NOYDB (testing and development)",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@noydb/core": "workspace:*"
  },
  "devDependencies": {
    "@noydb/core": "workspace:*",
    "@noydb/test-adapter-conformance": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vLannaAi/noydb.git",
    "directory": "packages/adapter-memory"
  }
}
