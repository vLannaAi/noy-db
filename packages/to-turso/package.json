{
  "name": "@noy-db/to-turso",
  "version": "0.1.0",
  "description": "Turso / libSQL adapter for noy-db — edge SQLite with built-in replication. Wraps @libsql/client through a small async shim that speaks the same noy-db store contract as @noy-db/to-sqlite.",
  "license": "MIT",
  "author": "vLannaAi <vicio@lanna.ai>",
  "homepage": "https://github.com/vLannaAi/noy-db/tree/main/packages/to-turso#readme",
  "repository": { "type": "git", "url": "https://github.com/vLannaAi/noy-db.git", "directory": "packages/to-turso" },
  "bugs": { "url": "https://github.com/vLannaAi/noy-db/issues" },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=18.0.0" },
  "scripts": { "build": "tsup", "test": "vitest run", "lint": "eslint src/", "typecheck": "tsc --noEmit" },
  "peerDependencies": { "@noy-db/hub": "workspace:*" },
  "devDependencies": { "@noy-db/hub": "workspace:*", "@types/node": "^22.0.0" },
  "keywords": ["noy-db", "to-turso", "turso", "libsql", "sqlite", "edge", "storage"]
}
