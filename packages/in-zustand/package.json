{
  "name": "@noy-db/in-zustand",
  "version": "0.1.0-pre.1",
  "description": "Zustand adapter for noy-db — factory that mirrors defineNoydbStore for Zustand users, auto-syncs state from noy-db change events, and supports optimistic mutations.",
  "license": "MIT",
  "author": "vLannaAi <vicio@lanna.ai>",
  "homepage": "https://github.com/vLannaAi/noy-db/tree/main/packages/in-zustand#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vLannaAi/noy-db.git",
    "directory": "packages/in-zustand"
  },
  "bugs": {
    "url": "https://github.com/vLannaAi/noy-db/issues"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@noy-db/hub": "workspace:*",
    "zustand": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@noy-db/hub": "workspace:*",
    "zustand": "^5.0.0"
  },
  "keywords": [
    "noy-db",
    "in-zustand",
    "zustand",
    "state",
    "react"
  ]
}
