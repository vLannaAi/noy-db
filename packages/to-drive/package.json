{
  "name": "@noy-db/to-drive",
  "version": "0.1.0",
  "description": "Google Drive bundle store for noy-db. Stores the whole vault as a single .noydb file in Drive's hidden appDataFolder; opaque ULID filenames never leak compartment names. Driver-agnostic — bring your own OAuth token.",
  "license": "MIT",
  "author": "vLannaAi <vicio@lanna.ai>",
  "homepage": "https://github.com/vLannaAi/noy-db/tree/main/packages/to-drive#readme",
  "repository": { "type": "git", "url": "https://github.com/vLannaAi/noy-db.git", "directory": "packages/to-drive" },
  "bugs": { "url": "https://github.com/vLannaAi/noy-db/issues" },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=18.0.0" },
  "scripts": { "build": "tsup", "test": "vitest run", "lint": "eslint src/", "typecheck": "tsc --noEmit" },
  "peerDependencies": { "@noy-db/hub": "workspace:*" },
  "devDependencies": {
    "@noy-db/hub": "workspace:*",
    "@types/node": "^22.0.0"
  },
  "keywords": ["noy-db", "to-drive", "google-drive", "oauth", "bundle", "storage", "zero-knowledge"]
}
