# ─── Dependencies ──────────────────────────────────────────────────────
node_modules/
.pnp.*
jspm_packages/

# ─── Build output ──────────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ─── Turbo / bundlers ──────────────────────────────────────────────────
.turbo/
.parcel-cache/
.next/
.nuxt/
.nitro/
.output/
.vercel/
.netlify/
.wrangler/

# ─── Coverage / test artefacts ─────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
.vitest-reports/

# ─── Pack artifacts ────────────────────────────────────────────────────
*.tgz
*.tar.gz
*.zip

# ─── OS junk ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── IDE / editor ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.swn
*~
.history/

# ─── AI assistant session data ─────────────────────────────────────────
# Anything under .claude, .cursor, .aider is session-local and may leak
# prompts, API keys, or scratch notes. Never commit.
.claude/
.cursor/
.cursorignore
.cursorrules
.aider*
.continue/
.github/copilot-*
.codeium*
.zed/

# ─── Secrets — environment files ───────────────────────────────────────
# `.env.example` is the one safe tracked variant.
.env
.env.*
!.env.example
*.env.local
*.env.production
*.env.staging

# ─── Secrets — credentials / keys / tokens ─────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.pkcs12
*.crt
*.cer
*.der
*.asc
*.gpg
*.kdbx
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
known_hosts
authorized_keys
credentials.json
credentials.yaml
credentials.yml
service-account*.json
*.token
token.json
oauth.json
.npmrc.local
.yarnrc.local
.pnpmrc.local
aws-credentials*
.aws/credentials
.ssh/
secrets/
private/

# ─── Session / cookies / local state ───────────────────────────────────
cookies.txt
session.json
*.session
*.lockfile.local
.firebaserc.local

# ─── Databases that may hold user data ─────────────────────────────────
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm
# Keep .db if it's a test fixture — gitignore hides root-level user data.
/*.db

# ─── Logs ──────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ─── Playwright / MCP / scratch ────────────────────────────────────────
.playwright-mcp/
test-results/
playwright-report/
blob-report/

# ─── npm manifest / lockfile-adjacent snapshots ────────────────────────
.npm-snapshot/
.yarn/cache/
.yarn/unplugged/

# ─── Generated typedoc API docs (regenerate via `pnpm docs`) ───────────
docs/api/

# ─── tsup intermediate artifacts ───────────────────────────────────────
**/tsup.config.bundled_*.mjs

# ─── Backup / scratch files ────────────────────────────────────────────
*.bak
*.backup
*.orig
*.old
*.tmp
*.temp
.backup/
backup/

# ─── Local overrides ───────────────────────────────────────────────────
# If a user wants to keep private test data locally, use `.local.*` —
# matched here, ignored globally.
*.local.*
/local/
/scratch/

# ─── Project metadata ──────────────────────────────────────────────────
# `.npmrc` is a common accidental-token surface (_authToken=...).
# `.changeset/` is kept local; release notes come through the workflow.
# `.github/` is ignored by default, but workflows are needed for CI —
# selectively allow `.github/workflows/`.
.npmrc
!**/playground/**/.npmrc
.changeset/
.github/*
!.github/workflows/
!.github/workflows/**

# ─── Local-only AI configs (not published) ─────────────────────────
CLAUDE.md
