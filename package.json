{
  "name": "noydb-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Zero-knowledge, offline-first, encrypted document store",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:ci": "turbo run test -- --coverage",
